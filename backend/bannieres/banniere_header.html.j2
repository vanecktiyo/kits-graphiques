<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<style>
  @font-face {
    font-family: 'Cabin';
    src: url('../../assets/fonts/Cabin.ttf');
    font-weight: 100 900;
  }

  :root {
    --fond:  {{ couleur_fond }};
    --texte: {{ couleur_texte }};
    --jaune: #FFD52B;
    --bouton: {{ couleur_bouton }};
    --bouton-texte: {{ couleur_bouton_texte }};
    --base: {{ base }}px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  /* Header d'accueil (hero) : grand message à gauche, offre (ou produit) à droite. */
  .banniere {
    width:  {{ largeur }}px;
    height: {{ hauteur }}px;
    background: var(--fond);
    font-family: 'Cabin', sans-serif;
    display: flex;
    flex-direction: {{ sens }};          /* "row" (large) ou "column" (étroit/mobile) */
    align-items: center;
    justify-content: center;
    gap: calc(var(--base) * 0.6);
    padding: calc(var(--base) * 0.5) calc(var(--base) * 0.9);
    overflow: hidden;
  }

  .bloc {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: calc(var(--base) * 0.4);
    min-width: 0;
  }
  .bloc-texte, .bloc-titre {
    flex: 1.2;
    align-items: {{ 'flex-start' if sens == 'row' else 'center' }};
    text-align: {{ 'left' if sens == 'row' else 'center' }};
  }
  .bloc-image, .bloc-offre { flex: 1; }
  .bloc-image { align-self: stretch; align-items: center; justify-content: center; }
  .bloc-image img { max-width: 100%; max-height: 100%; object-fit: contain; }
  .bloc-offre { align-items: {{ 'flex-start' if sens == 'row' else 'center' }}; }

  .titre {
    color: var(--texte);
    font-weight: 700;       /* Cabin Bold (strict charte) */
    font-size: calc(var(--base) * 1.1);
    line-height: 1.02;
  }

  .offre {
    display: flex; flex-wrap: wrap; align-items: center;
    justify-content: {{ 'flex-start' if sens == 'row' else 'center' }};
    max-width: 100%;
    gap: calc(var(--base) * 0.3);
  }
  .offre-label { color: var(--texte); font-weight: 700; font-size: calc(var(--base) * 0.42); }

  .prix {
    background: var(--jaune);
    color: #000;
    font-weight: 700;       /* Cabin Bold (strict charte) */
    padding: calc(var(--base) * 0.07) calc(var(--base) * 0.3);
    display: inline-flex;
    align-items: flex-start;
  }
  .prix .nombre { font-size: calc(var(--base) * 0.95); line-height: 1; }
  .prix .cents  { font-size: calc(var(--base) * 0.42); margin-top: calc(var(--base) * 0.04); }
  .offre-texte  { font-size: calc(var(--base) * 0.55); line-height: 1.05; }

  .cta {
    background: var(--bouton);
    color: var(--bouton-texte);
    font-weight: 700;
    font-size: calc(var(--base) * 0.4);
    padding: calc(var(--base) * 0.2) calc(var(--base) * 0.6);
    border-radius: 999px;
    white-space: nowrap;
  }
</style>
</head>
<body>
  <div class="banniere">
  {% if image_uri and sens == 'row' %}
    <div class="bloc bloc-texte">
      <div class="titre">{{ titre }}</div>
      <div class="offre">
        <span class="offre-label">{{ offre_label }}</span>
        <span class="prix">{% include "_prix.html.j2" %}</span>
      </div>
      {% if cta %}<div class="cta">{{ cta }}</div>{% endif %}
    </div>
    <div class="bloc bloc-image"><img src="{{ image_uri }}" alt=""></div>
  {% else %}
    <div class="bloc bloc-titre">
      <div class="titre">{{ titre }}</div>
    </div>
    <div class="bloc bloc-offre">
      <div class="offre">
        <span class="offre-label">{{ offre_label }}</span>
        <span class="prix">{% include "_prix.html.j2" %}</span>
      </div>
      {% if cta %}<div class="cta">{{ cta }}</div>{% endif %}
    </div>
  {% endif %}
  </div>
</body>
</html>
