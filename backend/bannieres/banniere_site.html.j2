<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<style>
  @font-face {
    font-family: 'Cabin';
    src: url('../../assets/fonts/Cabin.ttf');
    font-weight: 100 900;
  }

  :root {
    --bleu:  #253081;   /* carte (et fond de repli si pas d'image) */
    --jaune: #FFD52B;
    --base:  {{ base }}px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  /* Bannière SITE : image de la catégorie en fond (ou montage transversal de
     plusieurs catégories côte à côte) + carte bleue en surimpression. */
  .banniere {
    position: relative;
    width:  {{ largeur }}px;
    height: {{ hauteur }}px;
    {% if image_uri and not montage_images %}
    {# image adaptée à la hauteur du bandeau (pleine hauteur), puis répétée pour
       remplir toute la largeur ; le sujet est entièrement visible. #}
    background: var(--bleu) url('{{ image_uri }}') center / auto 100% repeat-x;
    {% else %}
    background: var(--bleu);
    {% endif %}
    font-family: 'Cabin', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: calc(var(--base) * 0.8);
    overflow: hidden;
  }

  /* Montage transversal : une bande d'images de catégories côte à côte,
     séparées par un espace (le bleu de la charte apparaît entre elles). */
  .fond {
    position: absolute;
    inset: 0;
    display: flex;
    gap: calc(var(--base) * 0.3);
  }
  .fond .cell {
    flex: 1;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }

  /* Carte bleue opaque en surimpression (au-dessus du fond / montage) */
  .carte {
    position: relative;
    z-index: 1;
    background: var(--bleu);
    padding: calc(var(--base) * 0.9) calc(var(--base) * 1.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: calc(var(--base) * 0.55);
    text-align: center;
    max-width: 82%;
  }

  /* Visuel d'événement transverse (ex. Black Friday) posé à côté de la carte.
     Hauteur en % du bandeau : le visuel s'adapte à la taille de la bannière. */
  .evenement {
    position: relative;
    z-index: 1;
    height: 70%;
    width: auto;
    max-width: 30%;
    object-fit: contain;
  }

  .titre {
    color: #fff;
    font-weight: 700;       /* Cabin Bold (strict charte) */
    font-size: calc(var(--base) * 1.05);
    line-height: 1.05;
  }

  .offre {
    display: flex;
    align-items: center;
    gap: calc(var(--base) * 0.35);
  }

  .offre-label {
    color: #fff;
    font-weight: 700;
    font-size: calc(var(--base) * 0.5);
  }

  .prix {
    background: var(--jaune);
    color: #000;
    font-weight: 700;       /* Cabin Bold (strict charte) */
    padding: calc(var(--base) * 0.08) calc(var(--base) * 0.32);
    display: inline-flex;
    align-items: flex-start;
  }
  .prix .nombre { font-size: calc(var(--base) * 1.0); line-height: 1; }
  .prix .cents  { font-size: calc(var(--base) * 0.45); margin-top: calc(var(--base) * 0.05); }
  .offre-texte  { font-size: calc(var(--base) * 0.62); line-height: 1.05; }

  /* Paliers de remise (grands formats) + date de validité */
  .paliers { display: flex; flex-wrap: wrap; justify-content: center; gap: calc(var(--base) * 0.3); }
  .palier {
    background: var(--jaune); color: #000; display: flex; flex-direction: column;
    align-items: flex-start; padding: calc(var(--base) * 0.12) calc(var(--base) * 0.3); line-height: 1.05;
  }
  .palier-cond { font-weight: 700; font-size: calc(var(--base) * 0.3); }
  .palier-val  { font-weight: 700; font-size: calc(var(--base) * 0.6); }
  .date-validite { color: #fff; font-weight: 700; font-size: calc(var(--base) * 0.42); }

  /* Bouton : uniquement pour les pubs illustrées (pas les bannières site). */
  .cta {
    background: #fff;
    color: var(--bleu);
    font-weight: 700;
    font-size: calc(var(--base) * 0.42);
    padding: calc(var(--base) * 0.22) calc(var(--base) * 0.6);
    border-radius: 999px;
    white-space: nowrap;
  }
</style>
</head>
<body>
  <div class="banniere">
    {% if montage_images %}
    <div class="fond">
      {% for img in montage_images %}<div class="cell" style="background-image: url('{{ img }}')"></div>{% endfor %}
    </div>
    {% endif %}
    {% if evenement_uri %}<img class="evenement" src="{{ evenement_uri }}" alt="">{% endif %}
    <div class="carte">
      <div class="titre">{{ titre }}</div>
      {% if date_validite %}<div class="date-validite">{{ date_validite }}</div>{% endif %}
      {% if montrer_paliers and paliers %}
      {% include "_paliers.html.j2" %}
      {% else %}
      <div class="offre">
        <span class="offre-label">{{ offre_label }}</span>
        <span class="prix">{% include "_prix.html.j2" %}</span>
      </div>
      {% endif %}
      {% if avec_cta and cta %}<div class="cta">{{ cta }}</div>{% endif %}
    </div>
  </div>
</body>
</html>
