<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<style>
  @font-face {
    font-family: 'Cabin';
    src: url('../../assets/fonts/Cabin.ttf');
    font-weight: 100 900;
  }

  :root {
    --fond:  {{ couleur_fond }};   /* couleur de fond choisie dans la palette charte */
    --texte: {{ couleur_texte }};  /* blanc sur fond foncé, bleu foncé sur fond clair */
    --jaune: #FFD52B;
    --bouton: {{ couleur_bouton }};
    --bouton-texte: {{ couleur_bouton_texte }};
    /* "base" = unité d'échelle calculée en Python selon le format. */
    --base: {{ base }}px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  .banniere {
    width:  {{ largeur }}px;
    height: {{ hauteur }}px;
    background: var(--fond);
    font-family: 'Cabin', sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: {{ justify }};   /* "center" (carré) ou "space-evenly" (vertical) */
    gap: calc(var(--base) * 0.7);
    padding: calc(var(--base) * 1.0);
    overflow: hidden;
    text-align: center;
  }

  .logo { height: calc(var(--base) * 1.4); width: auto; border-radius: calc(var(--base) * 0.18); }

  .titre {
    color: var(--texte);
    font-weight: 700;       /* Cabin Bold (strict charte) */
    font-size: calc(var(--base) * 1.5);
    line-height: 1.05;
  }

  .offre-label {
    color: var(--texte);
    font-weight: 700;
    font-size: calc(var(--base) * 0.85);
  }

  .prix {
    background: var(--jaune);
    color: #000;
    font-weight: 700;       /* Cabin Bold (strict charte) */
    padding: calc(var(--base) * 0.15) calc(var(--base) * 0.5);
    display: inline-flex;
    align-items: flex-start;
  }
  .prix .nombre { font-size: calc(var(--base) * 1.7); line-height: 1; }
  .prix .cents  { font-size: calc(var(--base) * 0.85); margin-top: calc(var(--base) * 0.14); }
  .offre-texte  { font-size: calc(var(--base) * 0.95); line-height: 1.05; }

  /* Paliers de remise (grands formats) + date de validité */
  .paliers { display: flex; flex-wrap: wrap; justify-content: center; gap: calc(var(--base) * 0.35); }
  .palier {
    background: var(--jaune); color: #000;
    display: flex; flex-direction: column; align-items: flex-start;
    padding: calc(var(--base) * 0.22) calc(var(--base) * 0.45); line-height: 1.1;
  }
  .palier-cond { font-weight: 700; font-size: calc(var(--base) * 0.4); }
  .palier-val  { font-weight: 700; font-size: calc(var(--base) * 0.95); }
  .date-validite { color: var(--texte); font-weight: 700; font-size: calc(var(--base) * 0.5); }

  /* Bouton d'action (affiché seulement si un CTA est demandé) */
  .cta {
    background: var(--bouton);
    color: var(--bouton-texte);
    font-weight: 700;
    font-size: calc(var(--base) * 0.55);
    padding: calc(var(--base) * 0.28) calc(var(--base) * 0.8);
    border-radius: 999px;
    white-space: nowrap;
  }
</style>
</head>
<body>
  <div class="banniere">
    {% if logo_uri %}<img class="logo" src="{{ logo_uri }}" alt="Gefradis">{% endif %}
    <div class="titre">{{ titre }}</div>
    {% if date_validite %}<div class="date-validite">{{ date_validite }}</div>{% endif %}
    {% if montrer_paliers and paliers %}
    {% include "_paliers.html.j2" %}
    {% else %}
    <div class="offre-label">{{ offre_label }}</div>
    <div class="prix">{% include "_prix.html.j2" %}</div>
    {% endif %}
    {% if cta %}<div class="cta">{{ cta }}</div>{% endif %}
  </div>
</body>
</html>
